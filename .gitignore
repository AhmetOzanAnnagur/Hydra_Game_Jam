# This file is used to ignore files which are difficult to diffuse in time.
# For more background information on this file, see the Core secrets documentation at Ivy (go/core-secrets).
# Before adding an exception to this file, please read the online documentation first.

# Ignore all local Python installations and caches
__pycache__/
*.pyc

# Ignore Mac .DS_Store files
.DS_Store

# Ignore all files in the Library directory used by Unity except metadata (.meta) files
/Library/*
!/Library/ShaderCache/
!/Library/Artifacts/

# Ignore the entire Temp directory
/Temp/
/Builds/
/Build/

# Visual Studio cache directory
.vs/
.vscode/

# Autogenerated VS/MD solution and project files
ExportedObj/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files are tracked, so as not to untrack files accidentally
!.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.unitypackage

# Crash dumps
crashes/
crash-*

# Uncomment this line if you wish to ignore the asset store tools plugin
# [Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
.idea/
.idea/
Assets/Plugins/Editor/JetBrains*

# Visual Studio Code
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Compiled binaries
[Bb]in/
[Oo]bj/

# IDEs
.idea/
*.swp
*.swo
*~

# OS files
Thumbs.db

# Game Jam specific
game buıld/
